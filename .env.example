# Secret shared by the QR code. Generate once: node -e "console.log(require('crypto').randomUUID())"
BANO_QR_KEY=replace-me-with-a-uuid

# Public URL of your frontend (used by CORS in the backend).
# Example: https://bano.tudominio.com
CORS_ORIGIN=*

# Port exposed by the frontend container on the host.
FRONT_PORT=8080

# Token used by the hardware sensor (Shelly via HA) to POST /sensor.
# Generate once: node -e "console.log(require('crypto').randomUUID())"
# If empty, the backend uses a random one on each restart (sensor won't work across restarts).
HARDWARE_TOKEN=replace-me-with-a-uuid

# How long (ms) without sensor reports before the state falls back to manual mode.
SENSOR_TIMEOUT_MS=300000
