# ─── Base de datos (Postgres) ───
# En Docker: se arma solo desde las vars POSTGRES_* de abajo.
# En Dokploy con Postgres gestionado: pegá acá la URL que te da Dokploy y
# dejá POSTGRES_* vacías (o ignorá la URL autogenerada del compose).
POSTGRES_USER=bano
POSTGRES_PASSWORD=cambiame_por_algo_seguro
POSTGRES_DB=bano
DB_PORT=5432

# ─── Backend ───
# JWT_SECRET: generalo con:  node -e "console.log(require('crypto').randomUUID())"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Tiempos del baño (en milisegundos)
LOCK_DURATION_MS=600000        # lock inicial: 10 min
CLAIM_WINDOW_MS=60000          # tiempo del siguiente en la fila para tomar el lock: 60 s
EXTRA_MINUTES_MS=60000         # cuánto suma cada "tiempo extra": 1 min
EXTRA_MAX=5                    # máximo de extras por lock

# CORS
CORS_ORIGIN=*

# ─── Front (solo local) ───
FRONT_PORT=8080
