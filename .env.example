# Secret shared by the QR code. Generate once: node -e "console.log(require('crypto').randomUUID())"
BANO_QR_KEY=replace-me-with-a-uuid

# Public URL of your frontend (used by CORS in the backend).
# Example: https://bano.tudominio.com
CORS_ORIGIN=*

# Port exposed by the frontend container on the host.
FRONT_PORT=8080
